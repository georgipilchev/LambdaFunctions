{
  "LambdaFunctionConfigurations": [
    {
      "Id": "VirusScanner",
      "Events": ["s3:ObjectCreated:*"],
      "Filter": {
        "Key": {
          "FilterRules": [
            {
              "Name": "prefix",
              "Value": "mods/"
            },
            {
              "Name": "suffix",
              "Value": ".zip"
            }
          ]
        }
      },
      "LambdaFunctionArn": "VIRUS_LAMBDA_ARN"
    },
    {
      "Id": "ImageProcessor",
      "Events": ["s3:ObjectCreated:*"],
      "Filter": {
        "Key": {
          "FilterRules": [
            {
              "Name": "prefix",
              "Value": "mods/"
            },
            {
              "Name": "suffix",
              "Value": "/original"
            }
          ]
        }
      },
      "LambdaFunctionArn": "IMAGE_LAMBDA_ARN"
    }
  ]
}
